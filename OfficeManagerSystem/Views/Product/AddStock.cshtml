@model Office.Model.Product

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark fw-bold">
                    <i class="bi bi-box-arrow-in-down"></i> Yeni Stok Girişi (Mal Kabul)
                </div>
                <div class="card-body bg-light">
                    
                    <h5 class="mb-3">@Model.Name <span class="badge bg-secondary">@Model.SkuCode</span></h5>
                    <p class="text-muted small">Bu üründen sisteme yeni adetler ekliyorsunuz.</p>

                    <form asp-action="AddStock" method="post">
                        <input type="hidden" name="productId" value="@Model.Id" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Kaç Adet Geldi?</label>
                            <input type="number" name="addedQuantity" class="form-control" min="1" placeholder="Örn: 5" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Teslim Edilen Depo</label>
                            <select name="locationId" class="form-select border-warning" asp-items="ViewBag.Depots" required>
                                <option value="">Depo seçiniz...</option>
                            </select>
                            <div class="form-text text-danger mt-1">İş kuralı gereği, yeni alınan eşyalar sadece depolara teslim edilebilir.</div>
                        </div>

                        <div class="d-flex justify-content-end">
                            <a asp-action="Index" class="btn btn-outline-secondary me-2">İptal</a>
                            <button type="submit" class="btn btn-warning fw-bold px-4">Stokları Ekle</button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>